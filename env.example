# Copy to .env and set values (see README). .env is gitignored.
#
#   cp env.example .env

# Required for gated-semantic-cache query / repl (OpenAI embeddings)
OPENAI_API_KEY=

# Optional: default for --openai-model when not passed on the CLI
# OPENAI_MODEL=text-embedding-3-small

# Default cosine floor for semantic cache hits (OpenAI embeddings; tune on labeled eval)
# SEMANTIC_THRESHOLD=0.86

# Optional neighbor judge (off by default). When enabled, noop allow-all is wired unless you
# replace the judge in code with an LLM-backed implementation.
# NEIGHBOR_JUDGE_ENABLED=0

# Gray zone: skip the judge at or above this cosine similarity (strong embedding match).
# NEIGHBOR_JUDGE_SIMILARITY_CEILING=0.94

# Skip the judge when top1 - runner_up >= this margin (clear ANN winner).
# NEIGHBOR_JUDGE_AMBIGUITY_MARGIN=0.02

# Cap neighbor judge invocations per request (best-effort; over-budget reuses skip the judge).
# NEIGHBOR_JUDGE_MAX_CALLS=2

# Downgrade SEMANTIC_OK to SKIP_CACHE when router confidence is below this floor.
# SEMANTIC_OK_MIN_ROUTE_CONFIDENCE=0.55

# Downgrade low-confidence EXACT_ONLY without a resolvable anchor to SEMANTIC_OK (semantic lookup).
# Set to none/off to keep the conservative live-only path for anchorless EXACT_ONLY.
# EXACT_ONLY_MIN_ROUTE_CONFIDENCE=0.55

# Optional post-retrieval LLM judge (wired when OPENAI_API_KEY is set unless disabled).
# SEMANTIC_CACHE_DEFAULT_JUDGE=1
# SEMANTIC_CACHE_JUDGE_MODEL=gpt-5-mini
# SEMANTIC_CACHE_JUDGE_TIMEOUT_SECONDS=5.0
# SEMANTIC_CACHE_JUDGE_REASONING_EFFORT=low
# SEMANTIC_CACHE_JUDGE_MAX_OUTPUT_TOKENS=128
# SEMANTIC_CACHE_JUDGE_CHAT_MAX_TOKENS=80
# SEMANTIC_CACHE_JUDGE_ANSWER_PREVIEW_CHARS=200
# SEMANTIC_CACHE_JUDGE_DEBUG=1
